proxmox_endpoint = "https://192.168.1.3:8006"

proxmox_api_token = "USER@REALM!TOKENID=UUID"
proxmox_insecure  = true

template    = "ubuntu26-template"
cores       = 4
memory      = 6144
disk_gb     = 80
storage     = "local-lvm"

vms = {
    zoro = {
      vm_name     = "vm-ubuntu26-zoro-01"
      target_node = "zoro"
      vm_id       = 210
      ipv4_cidr   = "192.168.1.21/23"
      description = "VM Ubuntu 26 desplegada en zoro"
    }
    nami = {
      vm_name     = "vm-ubuntu26-nami-01"
      target_node = "nami"
      vm_id       = 220
      ipv4_cidr   = "192.168.1.22/23"
      description = "VM Ubuntu 26 desplegada en nami"
    }
}

network_bridge = "vmbr0"
ipv4_gateway   = "192.168.0.1"

ciuser     = "ubuntu"
cipassword = null
ssh_keys   = ["ssh-ed25519 AAAA... user@host"]

tags        = "homelab,ubuntu26,k3s"
description = "VM Ubuntu 26 para el root module de Proxmox"
